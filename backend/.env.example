# =============================================================================
# TigreTrack — Variables de Entorno (Producción)
# =============================================================================

# Puerto del servidor Express
PORT=3000

# Base de datos PostgreSQL (Prisma ORM)
DATABASE_URL="postgresql://usuario:password@localhost:5432/tu_base"

# JWT — Secreto para firmar y verificar tokens de autenticación
JWT_SECRET="cambiar_por_un_secreto_seguro_y_largo"

# Correo electrónico (Nodemailer — Gmail SMTP)
MAIL_USER="tu_correo@gmail.com"
MAIL_PASS="tu_contraseña_de_aplicacion"

# URL del frontend (usada para enlaces en correos electrónicos)
FRONTEND_URL="http://localhost:5173"

# Google OAuth — Client ID para autenticación con Google
GOOGLE_CLIENT_ID="tu_google_client_id.apps.googleusercontent.com"

# Google Calendar — ID del calendario institucional
GOOGLE_CALENDAR_ID=""

# Google Calendar — Ruta al archivo JSON de Service Account
GOOGLE_SERVICE_ACCOUNT_PATH="./credentials/google-service-account.json"
